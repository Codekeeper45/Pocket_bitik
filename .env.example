# ════════════════════════════════════════════════════════════════
#  НАСТРОЙКИ БОТА
#  Скопируйте этот файл в .env и подставьте свои значения.
#  Команда для копирования:  cp .env.example .env   (Windows: copy .env.example .env)
#  НИКОМУ не показывайте готовый .env — это ваши ключи и доступы!
# ════════════════════════════════════════════════════════════════

# --- Telegram (ОБЯЗАТЕЛЬНО) ---
# Получить на https://my.telegram.org → API development tools
api_id=0000000
api_hash=ваш_api_hash_сюда

# --- ИИ-ключ для ответов (минимум — ОДИН ключ DeepSeek) ---
# DeepSeek — это «мозг» бота по умолчанию. Только этого ключа достаточно,
# чтобы бот запустился и работали .ask / .search / .digest / авто-ответ.
# Получить ключ: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-v4-pro

# ════════════════════════════════════════════════════════════════
#  НЕОБЯЗАТЕЛЬНЫЕ ключи ниже. Без них бот НЕ упадёт — просто
#  соответствующие функции работать не будут (см. таблицу в README).
#  Если ключа нет — оставьте поле пустым или удалите строку.
# ════════════════════════════════════════════════════════════════

# OpenRouter (необязательно) — нужен ТОЛЬКО для распознавания картинок,
# голосовых и видео-кружков внутри .ask. Без него медиа просто не читаются,
# текст чата при этом разбирается нормально. Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenCode (необязательно) — нужен ТОЛЬКО если вы хотите переключаться
# на модели Kimi / GLM / Qwen / MiniMax / MiMo / Hunyuan через .model.
OPENCODE_API_KEY=

# Google GenAI / Gemini TTS (необязательно) — нужен ТОЛЬКО для голосовых
# ответов в .ask (команда .voice + флаг -v). Без него бот отвечает текстом.
# Ключ: https://aistudio.google.com/apikey
# Можно указать несколько ключей через запятую (ротация при лимитах) —
# здесь или в GOOGLE_GENAI_API_KEYS.
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_API_KEYS=

# Fish Audio TTS (необязательно) — альтернативный движок озвучки с большим выбором
# голосов. Переключение: .voice engine fish · поиск/избранное: .voice fish.
# Ключ: https://fish.audio (раздел API). Модель по умолчанию s1 (можно s2-pro).
FISH_AUDIO_API_KEY=
FISH_TTS_MODEL=s1
